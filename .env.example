# ITviec Crawler Auth
ITVIEC_SESSION="your_session_token_here"
ITVIEC_TOKEN="your_auth_token_here"

# Database - Supabase
# DATABASE_URL: Use Transaction Pooler (Port 6543) for Vercel/Production
# Example: postgres://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgres://postgres:password@localhost:5432/postgres"

# DIRECT_URL: Use Direct Connection (Port 5432) for Prisma Migrations
# Example: postgres://postgres.xxx:password@db.xxx.supabase.co:5432/postgres
DIRECT_URL="postgres://postgres:password@localhost:5432/postgres"

# Python Configuration
# Path to python executable (fallback for local dev if not in path)
PYTHON_EXECUTABLE="python3"

NEXT_PUBLIC_SUPABASE_URL=your_public_supabase_url
# This should be your public anon key, not a postgres URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
# Needed for the Python sync script
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
