# ITviec Crawler Auth
ITVIEC_SESSION="your_session_token_here"
ITVIEC_TOKEN="your_auth_token_here"

# Database - Supabase
# DATABASE_URL: Use Transaction Pooler (Port 6543) for Vercel/Production
# Example: postgres://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgres://postgres:password@localhost:5432/postgres"

# DIRECT_URL: Use Direct Connection (Port 5432) for Prisma Migrations
# Example: postgres://postgres.xxx:password@db.xxx.supabase.co:5432/postgres
DIRECT_URL="postgres://postgres:password@localhost:5432/postgres"

# Python Configuration
# Path to python executable (fallback for local dev if not in path)
PYTHON_EXECUTABLE="python3"

# ─── Kaggle API (for --download-datasets) ───
# Create a token at https://www.kaggle.com/settings/account -> "Create New API Token".
# Paste the KGAT_... token value here (used as a Bearer token for direct downloads).
KAGGLE_API_TOKEN=your_api_token

NEXT_PUBLIC_SUPABASE_URL=your_public_supabase_url
# This should be your public anon key, not a postgres URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
# Needed for the Python sync script
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── AI Analysis (free LLM providers for --ai-analyze) ───
# Set any subset; --ai-analyze runs every provider that has a key and skips the rest.
# Groq (free, fast):        https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter (free models): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Google Gemini (free):     https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional model overrides (sensible free defaults used if unset):
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# GEMINI_MODEL=gemini-2.5-flash
